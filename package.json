{
  "name": "zandronum-vscode",
  "displayName": "zandronum-vscode",
  "description": "VS Code extension for Zandronum modding — DECORATE, ACS, lump syntax, build tools, and visual editors.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:decorate",
    "onLanguage:acs",
    "onLanguage:sndinfo",
    "onLanguage:textures",
    "onLanguage:cvarinfo",
    "onDebug:zandronum",
    "onCustomEditor:zandronum.spriteOffsetEditor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "decorate",
        "aliases": [
          "DECORATE",
          "decorate"
        ],
        "extensions": [
          ".dec",
          ".decorate"
        ],
        "filenames": [
          "DECORATE"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "acs",
        "aliases": [
          "ACS",
          "acs"
        ],
        "extensions": [
          ".acs"
        ],
        "filenames": [
          "SCRIPTS"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "mapinfo",
        "aliases": [
          "MAPINFO"
        ],
        "filenames": [
          "MAPINFO"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "sndinfo",
        "aliases": [
          "SNDINFO"
        ],
        "filenames": [
          "SNDINFO"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "gldefs",
        "aliases": [
          "GLDEFS"
        ],
        "filenames": [
          "GLDEFS"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "menudef",
        "aliases": [
          "MENUDEF"
        ],
        "filenames": [
          "MENUDEF"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "textures",
        "aliases": [
          "TEXTURES"
        ],
        "filenames": [
          "TEXTURES"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "animdefs",
        "aliases": [
          "ANIMDEFS"
        ],
        "filenames": [
          "ANIMDEFS"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "sbarinfo",
        "aliases": [
          "SBARINFO"
        ],
        "filenames": [
          "SBARINFO"
        ],
        "filenamePatterns": [
          "SBARINFO.*"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "cvarinfo",
        "aliases": [
          "CVARINFO"
        ],
        "filenames": [
          "CVARINFO"
        ],
        "filenamePatterns": [
          "CVARINFO.*"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "decorate",
        "scopeName": "source.decorate",
        "path": "./syntaxes/decorate.tmLanguage.json"
      },
      {
        "language": "acs",
        "scopeName": "source.acs",
        "path": "./syntaxes/acs.tmLanguage.json"
      },
      {
        "language": "mapinfo",
        "scopeName": "source.mapinfo",
        "path": "./syntaxes/mapinfo.tmLanguage.json"
      },
      {
        "language": "sndinfo",
        "scopeName": "source.sndinfo",
        "path": "./syntaxes/sndinfo.tmLanguage.json"
      },
      {
        "language": "gldefs",
        "scopeName": "source.gldefs",
        "path": "./syntaxes/gldefs.tmLanguage.json"
      },
      {
        "language": "menudef",
        "scopeName": "source.menudef",
        "path": "./syntaxes/menudef.tmLanguage.json"
      },
      {
        "language": "textures",
        "scopeName": "source.textures",
        "path": "./syntaxes/textures.tmLanguage.json"
      },
      {
        "language": "animdefs",
        "scopeName": "source.animdefs",
        "path": "./syntaxes/animdefs.tmLanguage.json"
      },
      {
        "language": "sbarinfo",
        "scopeName": "source.sbarinfo",
        "path": "./syntaxes/sbarinfo.tmLanguage.json"
      },
      {
        "language": "cvarinfo",
        "scopeName": "source.cvarinfo",
        "path": "./syntaxes/cvarinfo.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "decorate",
        "path": "./snippets/decorate.snippets.json"
      },
      {
        "language": "acs",
        "path": "./snippets/acs.snippets.json"
      }
    ],
    "commands": [
      {
        "command": "decorate.buildPK3",
        "title": "Build PK3"
      },
      {
        "command": "acs.compile",
        "title": "Compile ACS"
      },
      {
        "command": "acs.compileAllAndBuild",
        "title": "Compile All ACS and Build PK3"
      },
      {
        "command": "acs.compileCurrentAndBuild",
        "title": "Compile Current ACS and Build PK3"
      },
      {
        "command": "zandronum.editSpriteOffset",
        "title": "Edit Sprite Offset"
      },
      {
        "command": "zandronum.run",
        "title": "Run Zandronum"
      },
      {
        "command": "zandronum.buildAndRun",
        "title": "Build and Run Zandronum"
      },
      {
        "command": "acs.compileAllBuildAndRun",
        "title": "Compile All ACS, Build and Run"
      },
      {
        "command": "textures.openEditor",
        "title": "Open Texture Editor"
      },
      {
        "command": "decorate.previewOffset",
        "title": "Preview Weapon Offset"
      },
      {
        "command": "zandronum.addBaseResource",
        "title": "Add Base Resource"
      },
      {
        "command": "zandronum.refreshBaseResources",
        "title": "Refresh Base Resources"
      }
    ],
    "configuration": {
      "title": "Zandronum",
      "properties": {
        "zandronum-vscode.accPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ACC compiler executable. Leave empty to use 'acc' from system PATH."
        },
        "zandronum-vscode.accIncludePaths": {
          "type": "string",
          "default": "",
          "description": "Additional include directories for ACC (-i), separated by semicolons."
        },
        "zandronum-vscode.zandronumPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Zandronum executable. Leave empty to use 'zandronum' from system PATH."
        },
        "zandronum-vscode.pk3Root": {
          "type": "string",
          "default": "src",
          "description": "PK3 content root directory relative to workspace root. Resources and ACS files inside this directory get higher lookup priority."
        },
        "zandronum-vscode.baseResources": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Read-only base resource paths loaded before the workspace for symbol resolution. Supports .pk3/.zip archives and directories. Later entries override earlier ones; workspace always wins. .wad and .pk7 are not supported yet."
        },
        "zandronum-vscode.accOutputDir": {
          "type": "string",
          "default": "",
          "description": "Output directory for compiled .o files, relative to the workspace root. If empty, defaults to <pk3Root>/acs."
        },
        "zandronum-vscode.playpalPath": {
          "type": "string",
          "default": "",
          "description": "Path to an external PLAYPAL lump file or directory containing one. Supports relative paths (to workspace root) and absolute paths. Used for palette color preview in Translation properties."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "zandronum.spriteOffsetEditor",
        "displayName": "Sprite Offset Editor",
        "selector": [
          {
            "filenamePattern": "*.png"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "zandronum.editSpriteOffset",
          "when": "resourceExtname == .png",
          "group": "zandronum"
        }
      ],
      "editor/context": [
        {
          "command": "textures.openEditor",
          "when": "editorLangId == textures",
          "group": "textures"
        },
        {
          "command": "decorate.previewOffset",
          "when": "editorLangId == decorate",
          "group": "decorate"
        }
      ]
    },
    "configurationDefaults": {
      "[textures]": {
        "editor.colorDecoratorsLimit": 10000
      },
      "[decorate]": {
        "editor.colorDecoratorsLimit": 10000
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "fflate": "^0.8.3"
  }
}
