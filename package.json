{
  "name": "zandronum-vscode",
  "displayName": "zandronum-vscode",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:decorate",
    "onLanguage:acs",
    "onLanguage:sndinfo"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "decorate",
        "aliases": ["DECORATE", "decorate"],
        "extensions": [".dec", ".decorate"],
        "filenames": ["DECORATE"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "acs",
        "aliases": ["ACS", "acs"],
        "extensions": [".acs"],
        "filenames": ["SCRIPTS"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "mapinfo",
        "aliases": ["MAPINFO"],
        "filenames": ["MAPINFO"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "sndinfo",
        "aliases": ["SNDINFO"],
        "filenames": ["SNDINFO"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "gldefs",
        "aliases": ["GLDEFS"],
        "filenames": ["GLDEFS"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "menudef",
        "aliases": ["MENUDEF"],
        "filenames": ["MENUDEF"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "textures",
        "aliases": ["TEXTURES"],
        "filenames": ["TEXTURES"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "animdefs",
        "aliases": ["ANIMDEFS"],
        "filenames": ["ANIMDEFS"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      { "language": "decorate", "scopeName": "source.decorate", "path": "./syntaxes/decorate.tmLanguage.json" },
      { "language": "acs", "scopeName": "source.acs", "path": "./syntaxes/acs.tmLanguage.json" },
      { "language": "mapinfo", "scopeName": "source.mapinfo", "path": "./syntaxes/mapinfo.tmLanguage.json" },
      { "language": "sndinfo", "scopeName": "source.sndinfo", "path": "./syntaxes/sndinfo.tmLanguage.json" },
      { "language": "gldefs", "scopeName": "source.gldefs", "path": "./syntaxes/gldefs.tmLanguage.json" },
      { "language": "menudef", "scopeName": "source.menudef", "path": "./syntaxes/menudef.tmLanguage.json" },
      { "language": "textures", "scopeName": "source.textures", "path": "./syntaxes/textures.tmLanguage.json" },
      { "language": "animdefs", "scopeName": "source.animdefs", "path": "./syntaxes/animdefs.tmLanguage.json" }
    ],
    "snippets": [
      {
        "language": "decorate",
        "path": "./snippets/decorate.snippets.json"
      },
      {
        "language": "acs",
        "path": "./snippets/acs.snippets.json"
      }
    ],
    "commands": [
      {
        "command": "decorate.buildPK3",
        "title": "Build PK3"
      },
      {
        "command": "decorate.enterComplete",
        "title": "Complete Sprite Frame"
      },
      {
        "command": "acs.compile",
        "title": "Compile ACS"
      },
      {
        "command": "acs.compileAllAndBuild",
        "title": "Compile All ACS and Build PK3"
      }
    ],
    "keybindings": [
      {
        "command": "decorate.enterComplete",
        "key": "Enter",
        "when": "editorLangId == decorate"
      }
    ],
    "configuration": {
      "title": "Zandronum",
      "properties": {
        "zandronum-vscode.accPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ACC compiler executable. Leave empty to use 'acc' from system PATH."
        },
        "zandronum-vscode.accIncludePaths": {
          "type": "string",
          "default": "",
          "description": "Additional include directories for ACC (-i), separated by semicolons."
        },
        "zandronum-vscode.accOutputDir": {
          "type": "string",
          "default": "src/acs",
          "description": "Output directory for compiled .o files, relative to the workspace root."
        },
        "zandronum-vscode.playpalPath": {
          "type": "string",
          "default": "",
          "description": "Path to an external PLAYPAL lump file or directory containing one. Supports relative paths (to workspace root) and absolute paths. Used for palette color preview in Translation properties."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "archiver": "^7.0.1"
  }
}
