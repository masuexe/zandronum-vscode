{
  "A_Chase": {
    "params": [
      { "name": "melee", "type": "string", "optional": true },
      { "name": "missile", "type": "string", "optional": true },
      {
        "name": "flags",
        "type": "int",
        "optional": true,
        "mode": "bitmask",
        "enum": [
          { "name": "CHF_FASTCHASE", "value": 1, "desc": "Faster chase" },
          { "name": "CHF_NOPLAYACTIVE", "value": 2, "desc": "No active sound" },
          { "name": "CHF_NIGHTMAREFAST", "value": 4, "desc": "Nightmare speed" },
          { "name": "CHF_RESURRECT", "value": 8, "desc": "Can resurrect" },
          { "name": "CHF_DONTMOVE", "value": 16, "desc": "Don't move" }
        ]
      }
    ],
    "desc": "This is the standard monster walking function which has to be used in the walking frames of a monster. Typically, it is used in an actor's \"See\" state or a custom equivalent."
  },
  "A_FireBullets": {
    "params": [
