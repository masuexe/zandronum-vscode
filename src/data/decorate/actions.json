        "enum": [
          { "name": "FBF_USEAMMO", "value": 1, "desc": "The attack uses ammo (Set by default)" },
          { "name": "FBF_NORANDOM", "value": 2, "desc": "No active sound" },
          { "name": "FBF_EXPLICITANGLE", "value": 4, "desc": "Nightmare speed" },
          { "name": "FBF_NOPITCH", "value": 8, "desc": "Can resurrect" },
          { "name": "FBF_NOFLASH", "value": 16, "desc": "Don't move" },
          { "name": "FBF_NORANDOMPUFFZ", "value": 32, "desc": "Don't move" }
        ]
      },
      { "name": "range", "type": "float", "optional": true }
    ],
    "desc": "Fires multiple bullets"
  },
  "A_FireCustomMissile": {
