{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "SNDINFO",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#command-logical" },
        { "include": "#command-music" },
        { "include": "#keywords" },
        { "include": "#numbers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.sndinfo", "match": "//.*$" },
                { "name": "comment.block.sndinfo", "begin": "/\\*", "end": "\\*/" }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.sndinfo",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "name": "constant.character.escape.sndinfo", "match": "\\\\." }
                    ]
                }
            ]
        },
        "command-logical": {
            "patterns": [
                {
                    "name": "meta.command.sndinfo",
                    "begin": "(?i)(?:^|\\s)(\\$(?:ambient|alias|archivepath|attenuation|edfoverride|ifdoom|ifheretic|ifhexen|ifstrife|limit|map|mididevice|pitchshift|pitchshiftrange|playercompat|playeralias|playersound|playersounddup|random|registered|rolloff|singular|volume))\\b",
                    "beginCaptures": { "1": { "name": "keyword.control.sndinfo" } },
                    "end": "$",
                    "patterns": [
                        { "include": "#comments" },
                        { "include": "#strings" },
                        { "include": "#numbers" },
                        { "match": "(?i)\\b(male|female|other)\\b", "name": "constant.language.gender.sndinfo" },
                        { "match": "\\*[A-Za-z0-9_-]+", "name": "variable.other.logicalname.sndinfo" },
                        { "match": "[A-Za-z_][A-Za-z0-9_]*(?:/[A-Za-z0-9_]+)*", "name": "variable.other.logicalname.sndinfo" }
                    ]
                }
            ]
        },
        "command-music": {
            "patterns": [
                {
                    "name": "meta.command.sndinfo",
                    "begin": "(?i)(?:^|\\s)(\\$(?:musicalias|musicvolume))\\b",
                    "beginCaptures": { "1": { "name": "keyword.control.sndinfo" } },
                    "end": "$",
                    "patterns": [
                        { "include": "#comments" },
                        { "include": "#strings" },
                        { "include": "#numbers" },
                        { "match": "[A-Za-z0-9_]+(?:/[A-Za-z0-9_]+)*", "name": "entity.name.lump.sndinfo" }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                { "match": "^\\s*(?!\\$)([A-Za-z_][A-Za-z0-9_]*(?:/[A-Za-z0-9_]+)*)", "captures": { "1": { "name": "variable.other.logicalname.sndinfo" } } },
                { "match": "[A-Za-z0-9_]+(?:/[A-Za-z0-9_]+)*", "name": "entity.name.lump.sndinfo" }
            ]
        },
        "numbers": {
            "patterns": [
                { "match": "-?\\b[0-9]+\\.[0-9]*\\b", "name": "constant.numeric.float.sndinfo" },
                { "match": "-?\\b[0-9]+\\b", "name": "constant.numeric.integer.sndinfo" },
                { "match": "\\b0x[0-9a-fA-F]+\\b", "name": "constant.numeric.hex.sndinfo" }
            ]
        }
    },
    "scopeName": "source.sndinfo"
}
