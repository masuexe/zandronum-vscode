{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "TEXTURES",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#definition-keywords" },
        { "include": "#optional-keyword" },
        { "include": "#style-values" },
        { "include": "#translation-builtins" },
        { "include": "#properties" },
        { "include": "#numbers" },
        { "include": "#braces" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.textures", "match": "//.*$" },
                { "name": "comment.block.textures", "begin": "/\\*", "end": "\\*/" }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.textures",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "name": "constant.character.escape.color.textures", "match": "\\\\c(?:\\[[^\\]]*\\]|[A-Za-z-])" },
                        { "name": "constant.character.escape.textures", "match": "\\\\." }
                    ]
                }
            ]
        },
        "definition-keywords": {
            "patterns": [
                { "match": "(?i)\\b(Texture|WallTexture|Flat|Sprite|Graphic|Patch)\\b", "name": "keyword.declaration.textures" }
            ]
        },
        "optional-keyword": {
            "patterns": [
                { "match": "(?i)\\b(optional)\\b", "name": "keyword.other.optional.textures" }
            ]
        },
        "style-values": {
            "patterns": [
                { "match": "(?i)\\b(Copy|Translucent|Add|Subtract|ReverseSubtract|Modulate|CopyAlpha|CopyNewAlpha|Overlay)\\b", "name": "constant.language.style.textures" }
            ]
        },
        "translation-builtins": {
            "patterns": [
                { "match": "(?i)\\b(Inverse|Gold|Red|Green|Ice|Desaturate)\\b", "name": "constant.language.translation.textures" }
            ]
        },
        "properties": {
            "patterns": [
                { "match": "(?i)\\b(XScale|YScale|Offset|WorldPanning|NoDecals|NullTexture|FlipX|FlipY|UseOffsets|Rotate|Translation|Blend|Alpha|Style)\\b", "name": "keyword.other.property.textures" }
            ]
        },
        "numbers": {
            "patterns": [
                { "match": "-?\\b[0-9]+\\.[0-9]*\\b", "name": "constant.numeric.float.textures" },
                { "match": "-?\\b[0-9]+\\b", "name": "constant.numeric.integer.textures" },
                { "match": "\\b0x[0-9a-fA-F]+\\b", "name": "constant.numeric.hex.textures" }
            ]
        },
        "braces": {
            "patterns": [
                { "match": "[{}]", "name": "punctuation.section.block.textures" }
            ]
        }
    },
    "scopeName": "source.textures"
}
